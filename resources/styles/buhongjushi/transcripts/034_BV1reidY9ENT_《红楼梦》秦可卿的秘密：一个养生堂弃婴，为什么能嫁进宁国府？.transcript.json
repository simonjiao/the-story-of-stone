{
  "engine": "faster-whisper",
  "model": "base",
  "language": "zh",
  "language_probability": 1,
  "segments": [
    {
      "from": 0.0,
      "to": 17.88,
      "content": "吉林十二拆李琴可轻身上笼罩的迷悟最为浓重。红楼梦在刻画可轻时,许多情节的设置都让读折百思不得其解,以至于后世学者紧罗密谷进行所引,延伸出情绪。"
    },
    {
      "from": 17.88,
      "to": 27.08,
      "content": "可对于红楼纹本研究而言,情绪更像是红楼外转,因为它脱离了红楼梦的援助本身,"
    },
    {
      "from": 27.08,
      "to": 31.96,
      "content": "跳出援助来分析援助,这无疑是物理看花。"
    },
    {
      "from": 31.96,
      "to": 38.52,
      "content": "不宏敬思认为,红楼梦的真正价值就在于文学艺术本身。"
    },
    {
      "from": 38.52,
      "to": 42.88,
      "content": "西日前中书先生拒绝采访其言约,"
    },
    {
      "from": 42.88,
      "to": 48.64,
      "content": "如果你吃到一个鸡蛋觉得好吃,你又何必去认识下蛋的母鸡。"
    },
    {
      "from": 48.64,
      "to": 52.2,
      "content": "思以为红楼研究艺术如此,"
    },
    {
      "from": 52.64,
      "to": 60.32,
      "content": "红楼梦的价值在于书中的文笔艺术、人物塑造、人情事故、贵族文化风俗等等,"
    },
    {
      "from": 60.32,
      "to": 67.32,
      "content": "而不在于研究作者的吃喝拉撒,并通过现实对照寻找历史影射。"
    },
    {
      "from": 67.32,
      "to": 72.76,
      "content": "这种解读自许寻找红楼真以,实责无趣至极。"
    },
    {
      "from": 72.76,
      "to": 77.32,
      "content": "我等读者诸君还是稀取鸡蛋中的营养物质,"
    },
    {
      "from": 77.32,
      "to": 80.36,
      "content": "莫要整日盯着鸡屁股研究。"
    },
    {
      "from": 81.28,
      "to": 86.64,
      "content": "按照援助所记,秦可亲是秦也从养生堂抱回来的。"
    },
    {
      "from": 86.64,
      "to": 91.96,
      "content": "其原因是秦也半生无子,只能领养了秦可亲。"
    },
    {
      "from": 91.96,
      "to": 99.64,
      "content": "可其中的邏輯似乎不同,正如欧里捐在大官红楼中所产生的内班。"
    },
    {
      "from": 99.64,
      "to": 108.0,
      "content": "养生堂及亲出时普遍设立的预英堂,是专门收容出生器营的慈善机构。"
    },
    {
      "from": 108.0,
      "to": 116.84,
      "content": "是人机与道德意识,追求理想社会秩序,以此作为解决器营逆英问题的究竟措施。"
    },
    {
      "from": 116.84,
      "to": 126.16,
      "content": "因此,绝大部分是由一身一伤与地方官所私伴,以长江中下有之大事朕最为仇密。"
    },
    {
      "from": 126.16,
      "to": 131.28,
      "content": "无子的秦也从此处收养而女,似乎顺理成章。"
    },
    {
      "from": 131.28,
      "to": 137.12,
      "content": "然而,其中暗藏的玄机在于,自西州的宗法制度以来,"
    },
    {
      "from": 137.12,
      "to": 144.84,
      "content": "收养之目的从为宗到为家,都是出于此事成绩,宗条延续的需求。"
    },
    {
      "from": 144.84,
      "to": 151.84,
      "content": "因此一般而言,报养者都是以难因为多女英则极少。"
    },
    {
      "from": 151.84,
      "to": 158.04,
      "content": "秦也半生无子,以难收养孩子,必定受为了家族相伙成绩。"
    },
    {
      "from": 158.04,
      "to": 166.16,
      "content": "既然如此,他应该收养难因才对,为何收养了秦可亲,这似乎是说不通的。"
    },
    {
      "from": 166.16,
      "to": 172.6,
      "content": "不宏君以为,此观点之产生,乃是对红楼文本认知不足所知。"
    },
    {
      "from": 172.6,
      "to": 178.24,
      "content": "我们且看原主中,秦一家收养秦可亲的具体描述。"
    },
    {
      "from": 178.24,
      "to": 183.48,
      "content": "他父亲秦也现任营善狼,年级七十夫人走亡。"
    },
    {
      "from": 183.48,
      "to": 192.28,
      "content": "因当年无儿女,便向养生堂,抱了一个儿子并一个女儿,谁知儿子又死了,只剩女儿。"
    },
    {
      "from": 192.28,
      "to": 205.5,
      "content": "小名患可儿,长大时,生的形容扬挪性格风流,因素与假家有些瓜葛固结了亲,虚与假荣为妻。"
    },
    {
      "from": 205.5,
      "to": 215.18,
      "content": "秦也当年并不是只领养了一个秦可亲,还有一个难因,只是后来这个难因早事只剩下一个秦可亲。"
    },
    {
      "from": 215.18,
      "to": 223.82,
      "content": "秦也半生无子,与养生堂收养孩子时,并成儿女双权之原则领养一儿一女。"
    },
    {
      "from": 223.82,
      "to": 227.86,
      "content": "完全符合中国是家庭的生子向往。"
    },
    {
      "from": 227.86,
      "to": 237.82,
      "content": "而在儿子死后,秦也又不可能把养了一半的女儿扔掉,这既不符合他为关的世人身份,也不符合人性。"
    },
    {
      "from": 237.82,
      "to": 243.3,
      "content": "两个小猫小狗都会有感情激烦,何况是人?"
    },
    {
      "from": 243.3,
      "to": 249.42,
      "content": "这当中值得拿出来的一问是,秦可亲为什么能嫁进宁国府?"
    },
    {
      "from": 249.42,
      "to": 263.34,
      "content": "曹雪秦用一句,苏余家家有些瓜葛故杰了秦,将当中的英国逻辑草草带过,以至于后世学者苦思明响争论不休。"
    },
    {
      "from": 263.34,
      "to": 277.66,
      "content": "即使习近平红楼梦中的婚姻现象,秦可亲嫁进宁国府并不具有特殊性,只是学者们刻意将眼光聚焦在秦可亲身上,忽略了其他人的婚姻状况。"
    },
    {
      "from": 277.66,
      "to": 286.02,
      "content": "宁国府优势嫁给了家家阻掌嫁身,荣国府大坊行夫人嫁给了荣府长子假设。"
    },
    {
      "from": 286.02,
      "to": 298.98,
      "content": "如果说秦可亲的婚姻存在一问,那么优势行夫人的婚姻,是不是也应该一碗水端瓶,研究出个优学,行学,才算公平。"
    },
    {
      "from": 298.98,
      "to": 307.62,
      "content": "援助中对优势行夫人的家事介绍并不详细,但由行两家的家境似乎并不是特别优越。"
    },
    {
      "from": 307.62,
      "to": 317.1,
      "content": "比如优家的优老娘贪途经营前程,就将优二姐偷嫁给家脸,有默认假真对优三姐的骚扰。"
    },
    {
      "from": 317.1,
      "to": 327.58,
      "content": "如果优家当真是世家大俗,能和国公府平起平座,优老娘母女三人真不至于落入如此处境。"
    },
    {
      "from": 327.58,
      "to": 335.42,
      "content": "另有行夫人,自家的行大就无钱可花,还得专门跑到荣国府找行夫人要钱。"
    },
    {
      "from": 335.42,
      "to": 341.58,
      "content": "行夫人不给,行得全就在宁国府的厌惠上向假真满愿。"
    },
    {
      "from": 341.58,
      "to": 348.1,
      "content": "行夫人的旨女儿行修烟一家人,更是穷的租妙理的房子,长达十年。"
    },
    {
      "from": 348.1,
      "to": 353.18,
      "content": "最后实在没办法,才来到京都,投本行夫人。"
    },
    {
      "from": 353.18,
      "to": 357.86,
      "content": "相比这两人,秦可轻的条件已经算优越了。"
    },
    {
      "from": 357.86,
      "to": 365.7,
      "content": "许多学者非常执忧的江秦可轻嫁给假荣,总结为一个平语嫁进国公府。"
    },
    {
      "from": 365.7,
      "to": 368.78,
      "content": "这种观点是极为偏迫的。"
    },
    {
      "from": 368.78,
      "to": 374.38,
      "content": "对于秦可轻的种种处境问题,绝不能偏执于气应身份。"
    },
    {
      "from": 374.38,
      "to": 381.42,
      "content": "江移成为家府敌派正义的女性,解释为一个适敬顺民的可怜小媳妇。"
    },
    {
      "from": 381.42,
      "to": 386.78,
      "content": "所谓身份低威,心理自卑,委屈求权等等的解释,"
    },
    {
      "from": 386.78,
      "to": 391.5,
      "content": "都是交着在气应出身所做的扩大性延伸。"
    },
    {
      "from": 391.5,
      "to": 397.74,
      "content": "嫁给家府的并不是养生堂的气应,而是朝廷无品官员的女儿。"
    },
    {
      "from": 397.74,
      "to": 405.01,
      "content": "这是一般在探讨秦可轻的相关问题时,普遍忽略的一大重点。"
    },
    {
      "from": 405.01,
      "to": 407.53,
      "content": "最后就是秦可轻的桑里。"
    },
    {
      "from": 407.53,
      "to": 412.89,
      "content": "以红楼梦前八十回维句,您国府一共举办过两次桑里。"
    },
    {
      "from": 412.89,
      "to": 416.13,
      "content": "一次是秦可轻,一次是假禁。"
    },
    {
      "from": 416.13,
      "to": 422.73,
      "content": "可朝学秦对秦可轻的桑里描绘极为龙种,远远压过假禁。"
    },
    {
      "from": 422.73,
      "to": 429.77,
      "content": "秦可轻的桑里,不仅有八宫的计辩,还有京都四王在路边设理计棚。"
    },
    {
      "from": 429.77,
      "to": 432.73,
      "content": "这种待遇非寻常人可比。"
    },
    {
      "from": 432.73,
      "to": 439.09,
      "content": "为此一些学者认为,这是秦可轻来废太子之女的文本所证。"
    },
    {
      "from": 439.09,
      "to": 440.73,
      "content": "布红君则认为,"
    },
    {
      "from": 440.73,
      "to": 446.33,
      "content": "将秦可轻假禁的桑里进行对比,本身就是不明智的。"
    },
    {
      "from": 446.33,
      "to": 450.97,
      "content": "因为这当中涉及到一个文笔重复的问题。"
    },
    {
      "from": 450.97,
      "to": 456.49,
      "content": "朝学秦写红楼,堪称习子如今,绝不做重复之笔。"
    },
    {
      "from": 456.49,
      "to": 462.09,
      "content": "秦可轻来经临十二拆之一,又是红楼梦去世交草的一个人物,"
    },
    {
      "from": 462.09,
      "to": 465.73,
      "content": "他满足细细写来的创作要求。"
    },
    {
      "from": 465.73,
      "to": 467.61,
      "content": "而到了假禁的桑里,"
    },
    {
      "from": 467.61,
      "to": 476.49,
      "content": "朝学秦基本是一笔带过,把重点放在假针、假脸和邮而解邮三解身上,以展开后文。"
    },
    {
      "from": 476.49,
      "to": 481.69,
      "content": "如果再次想写桑里,就会和秦可轻桑里发生重复。"
    },
    {
      "from": 481.69,
      "to": 486.01,
      "content": "朝学秦这种极别的作家是不谢这么写的。"
    },
    {
      "from": 486.01,
      "to": 493.21,
      "content": "因此,秦可轻身上的诸多疑问,并不需要跳出红楼梦这本书来找答案,"
    },
    {
      "from": 493.21,
      "to": 496.89,
      "content": "也不需要进行历史影视才能解读。"
    },
    {
      "from": 496.89,
      "to": 502.57,
      "content": "这些疑问,用朝学秦留下的小说文本,基本就可以回答。"
    },
    {
      "from": 502.57,
      "to": 512.65,
      "content": "我们不能为了研究而研究,能用援助给出答案,还是先不要进行天马行空式的幻想。"
    },
    {
      "from": 512.65,
      "to": 518.09,
      "content": "今天的红楼解读就聊到这里,我们下个视频再会。"
    }
  ]
}