{
  "engine": "faster-whisper",
  "model": "base",
  "language": "zh",
  "language_probability": 1,
  "segments": [
    {
      "from": 0.72,
      "to": 22.12,
      "content": "《红楼梦》被称为封建社会百科权署,这一点是得到众多读者工人的。从人情事故角度来关,红楼也是一本人情事态百科权署。曹雪芹真正做到了,人情练达及文章。这种练达就通过红楼人物关系展现出来。"
    },
    {
      "from": 22.12,
      "to": 35.72,
      "content": "就以贾宝为例。他对贾家子孙的宠爱程度是不同的。贾家子魅力、贾母对王熙凤、林黛玉、贾太春的宠爱就远远胜过营传和稀纯。"
    },
    {
      "from": 35.72,
      "to": 42.72,
      "content": "因为营稀两人口齿寻常,不太会成欢长辈,所以容易被贾母忽视。"
    },
    {
      "from": 42.72,
      "to": 48.22,
      "content": "我们读者在预读过程中,也能感受到这种人情信息。"
    },
    {
      "from": 48.82,
      "to": 54.32,
      "content": "罪天会来事儿的孩子,往往更容易得到长辈的喜欢。"
    },
    {
      "from": 54.32,
      "to": 58.42,
      "content": "把这种思维放在贾家男性子孙身上。"
    },
    {
      "from": 58.42,
      "to": 64.12,
      "content": "习惯红楼梦文本情节,贾母似乎只宠爱贾宝玉一个人。"
    },
    {
      "from": 64.12,
      "to": 69.42,
      "content": "就是读者最直观的感受。其实这个答案并不准确。"
    },
    {
      "from": 69.42,
      "to": 75.42,
      "content": "宝玉的德宠能被读者直观的看到是因为男主视角的原因。"
    },
    {
      "from": 75.52,
      "to": 84.81,
      "content": "其实家母还一场宠爱另一个孙子,便是假设的儿子王西奉的丈夫,佳脸。"
    },
    {
      "from": 84.81,
      "to": 88.81,
      "content": "红楼第44回,变身不测,奉劫破处。"
    },
    {
      "from": 88.81,
      "to": 95.31,
      "content": "佳脸和扑人之七,暴而家的丝魂,被半路回家换衣服的奉劫发觉。"
    },
    {
      "from": 95.31,
      "to": 100.61,
      "content": "佳脸脑袖承怒,借着酒劲儿拔出一把劲,就要杀奉劫。"
    },
    {
      "from": 100.61,
      "to": 104.81,
      "content": "奉劫逃到家母住处,佳脸也追到此处。"
    },
    {
      "from": 105.21,
      "to": 108.71,
      "content": "曹学金如是记录佳脸心里。"
    },
    {
      "from": 108.71,
      "to": 114.41,
      "content": "义语未完,直见佳脸拿着劲感来,后面许多人跟着。"
    },
    {
      "from": 114.41,
      "to": 121.91,
      "content": "佳脸名仗着佳母素席疼他们,连母亲身母也无爱,故承强弄了来。"
    },
    {
      "from": 121.91,
      "to": 130.41,
      "content": "媳妇认王妇认见了,记得盟男主骂斗,这下流种子,你越发反了,老太太在这里了。"
    },
    {
      "from": 130.41,
      "to": 139.06,
      "content": "佳脸一斜着眼,倒,都是老太太惯着她,她才这样,连母也骂起来了。"
    },
    {
      "from": 139.06,
      "to": 147.96,
      "content": "辞助明确提到,佳脸仗着佳母素席疼她,而读者读到这里多少会觉得有些空洞。"
    },
    {
      "from": 147.96,
      "to": 154.86,
      "content": "佳母疼爱宝玉处处可见,佳母疼爱佳脸则似乎无处可寻。"
    },
    {
      "from": 154.86,
      "to": 164.76,
      "content": "如果我们刻意把视角放在佳母佳脸,两个人的情节交给上,就会发现草血情的确擅长埋伏比。"
    },
    {
      "from": 164.76,
      "to": 178.76,
      "content": "佳母和佳脸的关系确实有宠爱的成分在,甚至我们可以推测,当年佳宝玉还未出生之前,佳母最宠爱的孙子很可能就是佳脸。"
    },
    {
      "from": 178.76,
      "to": 185.46,
      "content": "若文证据,布红军认为原住中至少有三处情节可供证明。"
    },
    {
      "from": 185.46,
      "to": 198.66,
      "content": "其一,原住第13回林如海病重,写信让待遇回佳一趟,佳母专门点名要佳脸亲自互送,可见对佳脸是何等信任。"
    },
    {
      "from": 198.66,
      "to": 210.56,
      "content": "尤其林如海病事后,需要处理一系列后续释疑,包括举办桑里潜散下人,林佳一场分配等等可能出现的问题。"
    },
    {
      "from": 210.56,
      "to": 216.36,
      "content": "佳母若不是十分信任佳脸,端然不会让她亲自互送。"
    },
    {
      "from": 216.36,
      "to": 228.36,
      "content": "当然,此一例只能证明佳母对佳脸的能力是信任的,并不能证明佳母宠爱佳脸,那么我们再来看第二处例子。"
    },
    {
      "from": 228.56,
      "to": 236.46,
      "content": "仍是第44回,凤姐拨祝风波过后,刺日佳脸久醒,心中着实后悔。"
    },
    {
      "from": 236.46,
      "to": 248.46,
      "content": "佳母叫来佳脸凤姐平耳,大家一起审问佳脸,而佳脸深通宠欢之道,三言两语就将佳母一行人斗得大笑。"
    },
    {
      "from": 248.46,
      "to": 258.06,
      "content": "原住记,佳脸听佳母说,便爬起来,与凤姐做了一个意,笑到,原来是我的不是,"
    },
    {
      "from": 258.06,
      "to": 267.16,
      "content": "二奶奶饶过我吧,满屋里的人都笑了,佳母笑到,奉压头不许脑了,再脑我就脑了。"
    },
    {
      "from": 267.16,
      "to": 283.36,
      "content": "说着,又命人去叫了平耳来,命凤姐和佳脸两个安慰平耳,佳脸见了平耳越发酷不得了,所谓欺不如切借不如偷,听佳母一说便赶上来说道,"
    },
    {
      "from": 283.36,
      "to": 296.06,
      "content": "姑娘昨日受了驱了,都是我的不是,奶奶得罪了你,也是英文而起,我陪了不是不算外,还替你奶奶陪个不是,说着也做了一个意,"
    },
    {
      "from": 296.06,
      "to": 299.16,
      "content": "赢得佳母笑了,凤姐也笑了。"
    },
    {
      "from": 299.16,
      "to": 308.16,
      "content": "诸君戏评这段文字,佳脸的情商简正没得说,再没有人能比她处理得更好了。"
    },
    {
      "from": 308.76,
      "to": 315.76,
      "content": "佳脸先是当着重人给凤姐做一,赢斗的佳母大笑,誓怀了老太太的心。"
    },
    {
      "from": 315.76,
      "to": 326.76,
      "content": "随后又连向平耳到了两次欠,一次是为自己,一次是为凤姐,因为昨天凤姐一时激脑悟打了平耳。"
    },
    {
      "from": 326.76,
      "to": 336.56,
      "content": "如此以来,原本应该生气的凤姐,见丈夫替自己道歉,反而不好意思为佳脸的出轨发伙了。"
    },
    {
      "from": 336.96,
      "to": 345.56,
      "content": "最终是,佳母笑了,凤姐也忍不住笑了,原本的审问,居然变得轻松于快起来。"
    },
    {
      "from": 345.56,
      "to": 355.16,
      "content": "佳脸这么做,有很大一部分原因是为了佳母,当着佳母的面得成欢负贺,不能惹老太太生气。"
    },
    {
      "from": 355.16,
      "to": 363.36,
      "content": "所以后文理,连凤夫妻俩一回到佳中,便又因为出轨的事,哭闹满愿了一阵。"
    },
    {
      "from": 363.36,
      "to": 370.96,
      "content": "如果说,佳脸互送灵带预有赞送期能力的因素,可以将其归之为智商,"
    },
    {
      "from": 370.96,
      "to": 377.36,
      "content": "那么佳脸能根据具体环境成欢长辈,则可归之为情商。"
    },
    {
      "from": 377.36,
      "to": 382.36,
      "content": "双伤皆被的佳脸,很难不被佳母喜欢。"
    },
    {
      "from": 382.36,
      "to": 391.16,
      "content": "还有第三处例子,便是佳母和佳脸的说话模式,佳母偶尔还会翻旧帐调侃佳脸。"
    },
    {
      "from": 391.16,
      "to": 396.16,
      "content": "具体可见原住第46回,冤枉女士绝冤枉偶。"
    },
    {
      "from": 396.16,
      "to": 404.16,
      "content": "佳是强取冤枉,佳母因此大怒,待着谁骂谁,好不容易平息下来怒气,"
    },
    {
      "from": 404.16,
      "to": 411.16,
      "content": "女院们据在一起打牌,佳脸过来打探消息,平而劝她不要去装腔口,"
    },
    {
      "from": 411.16,
      "to": 416.16,
      "content": "佳脸便在佳母门口偷偷先连着往里看。"
    },
    {
      "from": 416.16,
      "to": 421.16,
      "content": "佳后被佳母看在眼里,于是就有了这么一番对话。"
    },
    {
      "from": 421.16,
      "to": 426.16,
      "content": "佳母一回身,佳脸不防,便没躲零例,佳母便问,"
    },
    {
      "from": 426.16,
      "to": 432.16,
      "content": "外头是谁,倒向个小子一身头,佳脸忙进去陪佳道,"
    },
    {
      "from": 432.16,
      "to": 441.16,
      "content": "大听老太太十四个出门,好欲被叫着,佳母道,既这么样怎么不进来,又做鬼做神的。"
    },
    {
      "from": 441.16,
      "to": 448.16,
      "content": "佳脸陪佳道,见老太太玩牌不敢惊动,不过叫媳妇出来问问,"
    },
    {
      "from": 448.16,
      "to": 453.16,
      "content": "佳母道,就忙到这一时,等佳家去你问多少问不得,"
    },
    {
      "from": 453.16,
      "to": 458.16,
      "content": "那一招你这么小心来着,又不知是来做耳暴神的,"
    },
    {
      "from": 458.16,
      "to": 463.16,
      "content": "也不知是来做探子的,鬼鬼碎碎的,到虎尾一跳。"
    },
    {
      "from": 463.16,
      "to": 468.16,
      "content": "什么好下流种子,你媳妇和我玩牌呢,还有半日的空,"
    },
    {
      "from": 468.16,
      "to": 473.16,
      "content": "你家去再和那照耳家的商量治你媳妇去吧,"
    },
    {
      "from": 473.16,
      "to": 478.16,
      "content": "说着众人都笑了,原样笑道,暴耳家的,"
    },
    {
      "from": 478.16,
      "to": 482.16,
      "content": "老祖宗有拉伤照耳家的,佳母也笑道,"
    },
    {
      "from": 482.16,
      "to": 486.16,
      "content": "可是我哪里记得什么抱着背着的。"
    },
    {
      "from": 486.16,
      "to": 491.16,
      "content": "再次处佳母居然展现出高级幽默的天分,"
    },
    {
      "from": 491.16,
      "to": 494.16,
      "content": "明明奉劫铺土的事早已过去了,"
    },
    {
      "from": 494.16,
      "to": 498.16,
      "content": "而且所谓的两人商量害奉劫,"
    },
    {
      "from": 498.16,
      "to": 503.16,
      "content": "其实是王岐峰边出来,帮助自己战聚道德至高点的。"
    },
    {
      "from": 503.16,
      "to": 506.16,
      "content": "佳母却借力实力,条砍佳脸说,"
    },
    {
      "from": 506.16,
      "to": 510.16,
      "content": "你媳妇和我玩牌,还有半日的空,"
    },
    {
      "from": 510.16,
      "to": 514.16,
      "content": "你回去和照耳家的商量治你媳妇去吧。"
    },
    {
      "from": 514.16,
      "to": 518.16,
      "content": "而且把暴耳家的说成了照耳家的,"
    },
    {
      "from": 518.16,
      "to": 521.16,
      "content": "被冤枉糾正后,又使用邪影耿说,"
    },
    {
      "from": 521.16,
      "to": 524.16,
      "content": "我哪里记得什么抱着背着的,"
    },
    {
      "from": 524.16,
      "to": 528.16,
      "content": "无形中达成了一种绝妙的幽默效果。"
    },
    {
      "from": 528.16,
      "to": 532.16,
      "content": "这与薛盘把唐营念成耕黄,"
    },
    {
      "from": 532.16,
      "to": 535.16,
      "content": "被佳母与糾正后,薛盘都能说,"
    },
    {
      "from": 535.16,
      "to": 538.16,
      "content": "我哪知道什么唐营果营的。"
    },
    {
      "from": 538.16,
      "to": 541.16,
      "content": "二者真有意取同工之妙。"
    },
    {
      "from": 541.16,
      "to": 545.16,
      "content": "尤其是薛盘犯了这样的错,独者上能理解,"
    },
    {
      "from": 545.16,
      "to": 549.16,
      "content": "佳母如此身份,也犯相同的错误,"
    },
    {
      "from": 549.16,
      "to": 553.16,
      "content": "其幽默效果比薛盘有过之而无不及。"
    },
    {
      "from": 553.16,
      "to": 557.16,
      "content": "佳母之所以能激发出幽默感,"
    },
    {
      "from": 557.16,
      "to": 561.16,
      "content": "跟佳脸是她从小宠爱的孙子有直接关系,"
    },
    {
      "from": 561.16,
      "to": 566.16,
      "content": "因为宠爱所以轻力,开启玩笑来才能有任由于。"
    },
    {
      "from": 566.16,
      "to": 569.16,
      "content": "因此,我们有理由认为,"
    },
    {
      "from": 569.16,
      "to": 573.16,
      "content": "红龙梦的人情事故体系是相对完善的。"
    },
    {
      "from": 574.16,
      "to": 577.16,
      "content": "草血仅只要留下某种结论性信息,"
    },
    {
      "from": 577.16,
      "to": 580.16,
      "content": "苏州就一定有相应的福笔对照,"
    },
    {
      "from": 580.16,
      "to": 584.16,
      "content": "只是独者由于阅读事业的局限,"
    },
    {
      "from": 584.16,
      "to": 588.16,
      "content": "王王很难发现这些隐藏性信息。"
    },
    {
      "from": 588.16,
      "to": 594.16,
      "content": "这就要求独者要以更加细致的阅读方式来品味红楼。"
    },
    {
      "from": 594.16,
      "to": 599.16,
      "content": "民主长独长心的原因不外乎就是如此。"
    },
    {
      "from": 599.16,
      "to": 602.16,
      "content": "今天的红楼解读就到这里,"
    },
    {
      "from": 602.16,
      "to": 604.16,
      "content": "我们下一个视频再会。"
    }
  ]
}