{
  "engine": "faster-whisper",
  "model": "base",
  "language": "zh",
  "language_probability": 1,
  "segments": [
    {
      "from": 0.0,
      "to": 22.76,
      "content": "红楼梦里有一些常人根本无法察觉的细节。第18回元非醒清,零行前嫌德非赏赐了许多礼物,上到家母假证,下到家中的小丝伙计、优领人等皆有赏赐可能。其中尤其值得注意的是下人们收到的赏赐。"
    },
    {
      "from": 23.44,
      "to": 32.2,
      "content": "外表里24端,清前100串,是赐与家母、王夫人,及猪子妹房中哪娘众压缓的。"
    },
    {
      "from": 32.2,
      "to": 50.4,
      "content": "假真、假脸、假环、假荣等皆是表里一份经可一双,其于,踩断百端,经营千两,预久华宴,是次东西两府,繁园中,管理工程,承设,大印及私细,掌灯猪人的。"
    },
    {
      "from": 50.4,
      "to": 56.68,
      "content": "外有清前500串,是次除意,优领,百姓,杂行人丁的。"
    },
    {
      "from": 56.68,
      "to": 64.72,
      "content": "从这里明显能看出,主资阶层和奴谱阶层收到的资理是完全不一样的。"
    },
    {
      "from": 64.72,
      "to": 69.56,
      "content": "主资们的资理有公断,经营课子,如意,念猪等等,"
    },
    {
      "from": 69.56,
      "to": 74.36,
      "content": "第一层下人们收到的礼物,在很单一,只有清前。"
    },
    {
      "from": 74.76,
      "to": 79.8,
      "content": "这里的清前二字需要注意,不同版本的协法不同,"
    },
    {
      "from": 79.8,
      "to": 89.24,
      "content": "比如继续本此处写的是清前,少了三点水,而更成本,以及其他版本,则写的是三点水的清。"
    },
    {
      "from": 89.24,
      "to": 95.28,
      "content": "借末小看了这一字之差,清前和清前存在很大的不同,"
    },
    {
      "from": 95.28,
      "to": 98.88,
      "content": "而且对红楼梦的语境也会造成影响。"
    },
    {
      "from": 98.88,
      "to": 102.88,
      "content": "诸君若是不解,且听不红君,细细说来。"
    },
    {
      "from": 103.28,
      "to": 108.76,
      "content": "先来说清前,许多红学家根据这一个字得出一个结论,"
    },
    {
      "from": 108.76,
      "to": 117.24,
      "content": "便是红楼梦诞生于前龙五年之后,因为清前是从前龙五年才开始著造的。"
    },
    {
      "from": 117.24,
      "to": 120.56,
      "content": "这里有必要解释一下什么是清前。"
    },
    {
      "from": 120.56,
      "to": 126.44,
      "content": "根据清朝文献通考的记载,清前的着造从前龙五年开始,"
    },
    {
      "from": 126.44,
      "to": 131.2,
      "content": "在此之前,同前的主要成分是同心千,"
    },
    {
      "from": 131.2,
      "to": 134.84,
      "content": "制成的颜色发黄成为黄浅。"
    },
    {
      "from": 134.84,
      "to": 140.96,
      "content": "前龙五年,浙江部正史张若镇,看到民间多把同前消毁,"
    },
    {
      "from": 140.96,
      "to": 144.0,
      "content": "用来制作气迷,从中余历,"
    },
    {
      "from": 144.0,
      "to": 148.96,
      "content": "就建议在黄浅的成分中加入一定比例的西。"
    },
    {
      "from": 148.96,
      "to": 154.4,
      "content": "这样制成的钱并不易销容,改制同气幸粹一岁。"
    },
    {
      "from": 154.4,
      "to": 157.88,
      "content": "钱龙皇帝采纳了这个建议。"
    },
    {
      "from": 157.88,
      "to": 162.0,
      "content": "也就是说,如果气序本里的清前二字鼠时,"
    },
    {
      "from": 162.0,
      "to": 167.84,
      "content": "就表明红楼梦写于前龙五年之后,不可能再次之前。"
    },
    {
      "from": 167.84,
      "to": 170.16,
      "content": "再来说三点水的清前,"
    },
    {
      "from": 170.16,
      "to": 173.64,
      "content": "他的意思跟上述清前完全不同。"
    },
    {
      "from": 173.64,
      "to": 179.12,
      "content": "在清朝,官方著造的同前体大而重,成色也叫好,"
    },
    {
      "from": 179.12,
      "to": 181.72,
      "content": "这样的同前流入市场之后,"
    },
    {
      "from": 181.72,
      "to": 186.0,
      "content": "一些投机份子为了谋取暴力私自助钱。"
    },
    {
      "from": 186.0,
      "to": 187.96,
      "content": "但由于脱工减料,"
    },
    {
      "from": 187.96,
      "to": 193.6,
      "content": "这种民间助造的钱毕往往各小姐宝内涵杂志。"
    },
    {
      "from": 193.6,
      "to": 196.36,
      "content": "于是,在市场流通过程中,"
    },
    {
      "from": 196.36,
      "to": 202.2,
      "content": "就会有官方助造的钱和民间助造的钱混在一起的情况。"
    },
    {
      "from": 202.2,
      "to": 206.2,
      "content": "尤其,我国古代一串钱是1000个同前,"
    },
    {
      "from": 206.2,
      "to": 208.92,
      "content": "里面难免优劣混杂。"
    },
    {
      "from": 208.92,
      "to": 215.2,
      "content": "一串钱里,如果假有4助钱100美以上,便被称为19钱。"
    },
    {
      "from": 215.2,
      "to": 219.48,
      "content": "4助钱超过200美,则被称为28钱。"
    },
    {
      "from": 219.48,
      "to": 227.24,
      "content": "而如果一串钱里,全部都是官方制造的优良钱毕,才能被称为清前。"
    },
    {
      "from": 227.24,
      "to": 230.92,
      "content": "把这层认识放置在红楼梦第18回,"
    },
    {
      "from": 230.92,
      "to": 235.84,
      "content": "假冤非给家中人赏钱,那必然是上等的清前。"
    },
    {
      "from": 235.84,
      "to": 240.12,
      "content": "而不可能是19钱28钱这样的折扣货。"
    },
    {
      "from": 240.12,
      "to": 243.28,
      "content": "看到这个亲自,我们可以想象的到,"
    },
    {
      "from": 243.28,
      "to": 247.64,
      "content": "一群太减工人,抬着满满当当的优质同前,"
    },
    {
      "from": 247.64,
      "to": 250.88,
      "content": "因意发放给假家住下人的场景,"
    },
    {
      "from": 250.88,
      "to": 253.2,
      "content": "同前摩擦的当当之生,"
    },
    {
      "from": 253.2,
      "to": 256.28,
      "content": "仿佛就在我们耳边想着。"
    },
    {
      "from": 256.28,
      "to": 261.04,
      "content": "而如果是清前,则是经由参杂西成分的折扣钱,"
    },
    {
      "from": 261.04,
      "to": 264.96,
      "content": "似乎有损红楼梦,原非上次的危言。"
    },
    {
      "from": 264.96,
      "to": 267.52,
      "content": "故而,目前除了气序本,"
    },
    {
      "from": 267.52,
      "to": 271.88,
      "content": "大部分吉他版本都用的是三点水的清前。"
    },
    {
      "from": 271.88,
      "to": 275.4,
      "content": "由以自可亏红楼梦的历史文化内涵,"
    },
    {
      "from": 275.4,
      "to": 280.4,
      "content": "此书确实当得起四大民主之首的名号。"
    },
    {
      "from": 280.4,
      "to": 282.88,
      "content": "今天的红楼解读就聊到这里,"
    },
    {
      "from": 282.88,
      "to": 284.84,
      "content": "我们下个视频再会。"
    }
  ]
}