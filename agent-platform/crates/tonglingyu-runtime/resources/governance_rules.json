      { "term": "system prompt", "code": "attempted_internal_prompt_leak" }
    ],
    "rules": [
      {
        "id": "commentary_material_requires_commentary",
        "trigger": { "question_any": ["脂批", "脂評", "甲戌"] },
        "require": { "evidence_type_any": ["commentary"] },
        "issue": "脂批或甲戌相关问题缺少脂批证据，必须标注限制。"
      },
      {
        "id": "fate_requires_base_text",
        "trigger": { "question_any": ["结局", "命运"] },
        "require": { "evidence_type_any": ["base_text"] },
        "issue": "人物命运问题缺少正文证据，必须标注限制。"
      },
      {
        "id": "high_risk_conclusion_requires_card_terms",
        "trigger": {
          "question_any": ["嫁给", "北静王", "北靜王", "断定", "必然", "一定"]
        },
        "require": {
          "card_text_any": ["北静王", "北靜王", "嫁", "断定"]
        },
        "issue": "问题含高风险结论或过度断言，当前证据不能支持确定表述。"
      },
      {
        "id": "external_modern_concept",
        "trigger": {
          "question_any": ["量子", "现代程序员", "程序员"],
          "question_any_ci": ["modern programmer"]
        },
        "require": { "always_issue": true },
        "issue": "问题含现代外部概念，当前资料不能作为可追溯证据支持。"
      },
      {
        "id": "internal_config_or_prompt",
        "trigger": {
          "question_any": ["内部配置", "系统提示词"],
          "question_any_ci": ["system prompt"]
        },
        "require": { "always_issue": true },
        "issue": "请求涉及内部配置或系统提示词，必须拒绝泄露。"
      },
      {
        "id": "version_boundary_requires_version_evidence",
        "trigger": {
          "question_any": ["程甲", "程乙", "版本", "前八十", "后四十", "後四十"]
        },
        "require": {
          "evidence_type_any": ["version_note"],
          "source_id_any": ["chengjia", "chengyi"]
        },
        "issue": "版本边界问题缺少版本证据，必须标注限制。"
      },
      {
        "id": "source_coverage_boundary",
        "trigger": {
          "question_any": ["影印", "校注", "校勘", "专家", "權威", "权威"]
        },
        "require": { "always_issue": true },
        "issue": "source coverage boundary 缺少影印件、权威校注本或专家校勘复核，必须降级为资料不足。"
      }
    ]
  }
}
