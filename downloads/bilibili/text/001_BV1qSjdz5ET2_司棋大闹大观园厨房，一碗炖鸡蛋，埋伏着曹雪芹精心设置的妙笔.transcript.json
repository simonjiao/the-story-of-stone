  "language": "zh",
  "postprocess": "hongloumeng_term_corrections_v2",
  "segments": [
    {
      "from": 0.0,
      "to": 3.0,
      "content": "红楼梦里有很多绝妙文笔"
    },
    {
      "from": 3.0,
      "to": 8.5,
      "content": "这种绝妙文字不仅出现在宝黛钗主角等人身上"
    },
    {
      "from": 8.5,
      "to": 11.5,
      "content": "一些小人物也被雨露均沾"
    },
    {
      "from": 11.5,
      "to": 14.5,
      "content": "中国古典小说四大名着里"
    },
    {
      "from": 14.5,
      "to": 18.0,
      "content": "小人物永远被作者当成炮灰"
    },
    {
      "from": 18.0,
      "to": 22.5,
      "content": "只有红楼给了这些小人物展露头角的机会"
    },
    {
      "from": 22.5,
      "to": 27.5,
      "content": "而且曹雪芹一出手便不同反响力透纸背"
    },
    {
      "from": 28.0,
      "to": 29.5,
      "content": "第六十一回"
    },
    {
      "from": 29.5,
      "to": 32.0,
      "content": "投鼠忌器宝玉瞒赃"
    },
    {
      "from": 32.0,
      "to": 34.5,
      "content": "判冤决狱平儿行权"
    },
    {
      "from": 34.5,
      "to": 36.0,
      "content": "在这一回开篇"
    },
    {
      "from": 36.0,
      "to": 38.5,
      "content": "曹雪芹就写了一场闹剧"
    },
    {
      "from": 38.5,
      "to": 41.5,
      "content": "也就是我们读者非常熟悉的"
    },
    {
      "from": 41.5,
      "to": 44.0,
      "content": "司棋打砸厨房"
    },
    {
      "from": 44.0,
      "to": 46.5,
      "content": "这场闹剧写得极好"
    },
    {
      "from": 46.5,
      "to": 48.5,
      "content": "尤其各种细节"
    },
    {
      "from": 48.5,
      "to": 51.5,
      "content": "非有悟性之读者难窥其妙"
    },
    {
      "from": 51.5,
      "to": 53.5,
      "content": "如果是寻常读者"
    },
    {
      "from": 53.5,
      "to": 55.5,
      "content": "只取其故事而已"
    },
    {
      "from": 55.5,
      "to": 58.5,
      "content": "不免辜负了曹公苦心"
    },
    {
      "from": 58.5,
      "to": 59.5,
      "content": "起因是"
    },
    {
      "from": 59.5,
      "to": 61.5,
      "content": "迎春房里的小丫鬟"
    },
    {
      "from": 61.5,
      "to": 63.5,
      "content": "莲花儿来厨房传话"
    },
    {
      "from": 63.5,
      "to": 65.5,
      "content": "让柳家媳妇"
    },
    {
      "from": 65.5,
      "to": 67.5,
      "content": "做一碗鸡蛋羹给司棋"
    },
    {
      "from": 67.5,
      "to": 70.5,
      "content": "这本是一件再小不过的事"
    },
    {
      "from": 70.5,
      "to": 73.5,
      "content": "曹雪芹偏能平地起风波"
    },
    {
      "from": 73.5,
      "to": 76.5,
      "content": "酝酿出一场矛盾冲突"
    },
    {
      "from": 76.5,
      "to": 79.5,
      "content": "我们先来看原著这段"
    },
    {
      "from": 79.5,
      "to": 81.5,
      "content": "忽见迎春房里小丫头"
    },
    {
      "from": 81.5,
      "to": 83.5,
      "content": "莲花走来说"
    },
    {
      "from": 83.5,
      "to": 84.5,
      "content": "司棋姐姐说了"
    },
    {
      "from": 84.5,
      "to": 87.5,
      "content": "要碗鸡蛋炖得嫩嫩的"
    },
    {
      "from": 87.5,
      "to": 88.5,
      "content": "柳家的道"
    },
    {
      "from": 88.5,
      "to": 90.5,
      "content": "就是这样尊贵"
    },
    {
      "from": 90.5,
      "to": 91.5,
      "content": "不知怎地"
    },
    {
      "from": 91.5,
      "to": 93.5,
      "content": "今年这鸡蛋短得很"
    },
    {
      "from": 93.5,
      "to": 96.5,
      "content": "十个钱一个还找不出来"
    },
    {
      "from": 96.5,
      "to": 99.5,
      "content": "昨儿上头给亲戚家送粥米去"
    },
    {
      "from": 99.5,
      "to": 101.5,
      "content": "四五个买办出去"
    },
    {
      "from": 101.5,
      "to": 103.5,
      "content": "好容易才凑了二千个来"
    },
    {
      "from": 103.5,
      "to": 105.5,
      "content": "我哪里找去"
    },
    {
      "from": 105.5,
      "to": 108.5,
      "content": "你说给她改日吃吧"
    },
    {
      "from": 108.5,
      "to": 110.5,
      "content": "这里诸君要注意"
    },
    {
      "from": 110.5,
      "to": 112.5,
      "content": "红楼梦前文从没有提起过"
    },
    {
      "from": 112.5,
      "to": 114.5,
      "content": "莲花这个小丫鬟"
    },
    {
      "from": 114.5,
      "to": 116.5,
      "content": "这里是她第一次出现"
    },
    {
      "from": 116.5,
      "to": 119.5,
      "content": "为什么要给她起名莲花"
    },
    {
      "from": 119.5,
      "to": 121.5,
      "content": "用意很明显"
    },
    {
      "from": 121.5,
      "to": 123.5,
      "content": "曹雪芹是随文生名"
    },
    {
      "from": 123.5,
      "to": 125.5,
      "content": "所以此处有一句脂批"
    },
    {
      "from": 125.5,
      "to": 129.5,
      "content": "写道是“总是写春景将残”"
    },
    {
      "from": 129.5,
      "to": 132.5,
      "content": "莲花是盛夏时节的植物"
    },
    {
      "from": 132.5,
      "to": 134.5,
      "content": "预示着春天已经过去"
    },
    {
      "from": 134.5,
      "to": 136.5,
      "content": "酷暑即将到来"
    },
    {
      "from": 136.5,
      "to": 139.5,
      "content": "百花也到了凋零的时候"
    },
    {
      "from": 139.5,
      "to": 141.5,
      "content": "或有诸君不信"
    },
    {
      "from": 141.5,
      "to": 144.5,
      "content": "认为此观点不过是不红君"
    },
    {
      "from": 144.5,
      "to": 146.5,
      "content": "天马行空的自我意想"
    },
    {
      "from": 146.5,
      "to": 149.5,
      "content": "实有过度解读之嫌疑"
    },
    {
      "from": 149.5,
      "to": 152.5,
      "content": "那么不妨继续往下看"
    },
    {
      "from": 152.5,
      "to": 154.5,
      "content": "诸君且看第六十回"
    },
    {
      "from": 154.5,
      "to": 156.5,
      "content": "茉莉粉替去蔷薇硝"
    },
    {
      "from": 156.5,
      "to": 159.5,
      "content": "赵姨娘大闹怡红院之前"
    },
    {
      "from": 159.5,
      "to": 161.5,
      "content": "于路上遇见的婆子"
    },
    {
      "from": 161.5,
      "to": 163.5,
      "content": "名叫夏婆子"
    },
    {
      "from": 163.5,
      "to": 165.5,
      "content": "夏婆子怂恿赵姨娘"
    },
    {
      "from": 165.5,
      "to": 167.5,
      "content": "找芳官的麻烦"
    },
    {
      "from": 167.5,
      "to": 170.5,
      "content": "后探春及时赶来劝住赵姨娘"
    },
    {
      "from": 170.5,
      "to": 173.5,
      "content": "却有藕官暗中告状探春"
    },
    {
      "from": 173.5,
      "to": 176.5,
      "content": "收拾夏婆子怂恿的赵姨娘"
    },
    {
      "from": 176.5,
      "to": 178.5,
      "content": "这话被丫鬟翠墨听到"
    },
    {
      "from": 178.5,
      "to": 180.5,
      "content": "借着买糕的机会"
    },
    {
      "from": 180.0,
      "to": 185.0,
      "content": "又告诉了小蝉,小蝉是夏婆子的外孙女"
    },
    {
      "from": 185.0,
      "to": 189.0,
      "content": "于是消息再次传递到夏婆子耳朵里"
    },
    {
      "from": 189.0,
      "to": 193.0,
      "content": "无论是夏婆子的虾还是小蝉的蝉"
    },
    {
      "from": 193.0,
      "to": 196.0,
      "content": "都是夏天才有的产物"
    },
    {
      "from": 196.0,
      "to": 198.0,
      "content": "大观园内的矛盾冲突"
    },
    {
      "from": 198.0,
      "to": 201.0,
      "content": "就在这些名字里被悄悄埋伏"
    },
    {
      "from": 201.0,
      "to": 204.0,
      "content": "直言再说春景将残"
    },
    {
      "from": 204.0,
      "to": 206.0,
      "content": "预示着百花的凋零"
    },
    {
      "from": 206.0,
      "to": 208.0,
      "content": "之后抄检大观园"
    },
    {
      "from": 208.0,
      "to": 211.0,
      "content": "司棋、晴雯、芳官这些丫鬟"
    },
    {
      "from": 211.0,
      "to": 213.0,
      "content": "果然都被撵出门"
    },
    {
      "from": 213.0,
      "to": 215.0,
      "content": "这就是春景将残"
    },
    {
      "from": 215.0,
      "to": 219.0,
      "content": "盛夏季节的隐形暗示"
    },
    {
      "from": 219.0,
      "to": 220.0,
      "content": "言归正传"
    },
    {
      "from": 220.0,
      "to": 223.0,
      "content": "再说回鸡蛋羹事件"
    },
    {
      "from": 223.0,
      "to": 226.0,
      "content": "莲花儿问柳家媳妇要一碗炖鸡蛋"
    },
    {
      "from": 226.0,
      "to": 229.0,
      "content": "柳家媳妇说的第一句话是"
    },
    {
      "from": 229.0,
      "to": 231.0,
      "content": "就是这样尊贵"
    },
    {
      "from": 231.0,
      "to": 233.0,
      "content": "听到这句话"
    },
    {
      "from": 233.0,
      "to": 235.0,
      "content": "我们就能判断出"
    },
    {
      "from": 235.0,
      "to": 238.0,
      "content": "她是不愿意给这碗炖鸡蛋的"
    },
    {
      "from": 238.0,
      "to": 241.0,
      "content": "不红君每次看到这里"
    },
    {
      "from": 241.0,
      "to": 243.0,
      "content": "不红君都忍不住感叹"
    },
    {
      "from": 243.0,
      "to": 246.0,
      "content": "曹雪芹深刻的洞察能力"
    },
    {
      "from": 246.0,
      "to": 248.0,
      "content": "莲花儿要炖鸡蛋"
    },
    {
      "from": 248.0,
      "to": 250.0,
      "content": "柳家媳妇不直接说没有"
    },
    {
      "from": 250.0,
      "to": 253.0,
      "content": "而先说一大通解释的话"
    },
    {
      "from": 253.0,
      "to": 256.0,
      "content": "以验证没有鸡蛋这个事实"
    },
    {
      "from": 256.0,
      "to": 259.0,
      "content": "此种说话风格十分符合"
    },
    {
      "from": 259.0,
      "to": 262.0,
      "content": "柳家媳妇这样的中年妇女"
    },
    {
      "from": 262.0,
      "to": 264.0,
      "content": "在现实生活中这样的人"
    },
    {
      "from": 264.0,
      "to": 266.0,
      "content": "也尤其常见"
    },
    {
      "from": 266.0,
      "to": 269.0,
      "content": "柳家媳妇的话说得虽多"
    },
    {
      "from": 269.0,
      "to": 271.0,
      "content": "却说不到点子上"
    },
    {
      "from": 271.0,
      "to": 272.0,
      "content": "她说"
    },
    {
      "from": 272.0,
      "to": 274.0,
      "content": "今年这鸡蛋短得很"
    },
    {
      "from": 274.0,
      "to": 276.0,
      "content": "十个钱一个还找不出来"
    },
    {
      "from": 276.0,
      "to": 279.0,
      "content": "昨儿上头给亲戚家送粥米去"
    },
    {
      "from": 279.0,
      "to": 281.0,
      "content": "四五个买办出去"
    },
    {
      "from": 281.0,
      "to": 284.0,
      "content": "好容易才凑了二千个来"
    },
    {
      "from": 284.0,
      "to": 287.0,
      "content": "柳家媳妇这是在混淆视听"
    },
    {
      "from": 287.0,
      "to": 289.0,
      "content": "甭管鸡蛋如何贵"
    },
    {
      "from": 289.0,
      "to": 291.0,
      "content": "如何难买"
    },
    {
      "from": 291.0,
      "to": 294.0,
      "content": "这都是荣国府公中买办操心的事"
    },
    {
      "from": 294.0,
      "to": 296.0,
      "content": "公中采购完鸡蛋"
    },
    {
      "from": 296.0,
      "to": 298.0,
      "content": "会按照固定分例"
    },
    {
      "from": 298.0,
      "to": 300.0,
      "content": "分配到大观园厨房"
    },
    {
      "from": 300.0,
      "to": 302.0,
      "content": "她只负责接收鸡蛋"
    },
    {
      "from": 302.0,
      "to": 305.0,
      "content": "然后给小姐丫鬟们做饭"
    },
    {
      "from": 305.0,
      "to": 308.0,
      "content": "所以她的解释是苍白的"
    },
    {
      "from": 308.0,
      "to": 310.0,
      "content": "仅仅是为了拒绝这碗"
    },
    {
      "from": 310.0,
      "to": 313.0,
      "content": "炖鸡蛋而找出来的理由"
    },
    {
      "from": 313.0,
      "to": 315.0,
      "content": "后续的司棋打砸厨房"
    },
    {
      "from": 315.0,
      "to": 317.0,
      "content": "并不是一个偶然性事件"
    },
    {
      "from": 317.0,
      "to": 319.0,
      "content": "早在炖鸡蛋之前"
    },
    {
      "from": 319.0,
      "to": 321.0,
      "content": "就曾发生过类似的事"
    },
    {
      "from": 321.0,
      "to": 323.0,
      "content": "因为莲花儿紧接着就说"
    },
    {
      "from": 323.0,
      "to": 325.0,
      "content": "前儿要吃豆腐"
    },
    {
      "from": 325.0,
      "to": 326.0,
      "content": "你弄了些骚的"
    },
    {
      "from": 326.0,
      "to": 328.0,
      "content": "叫她说了我一顿"
    },
    {
      "from": 328.0,
      "to": 331.0,
      "content": "今天要鸡蛋又没有了"
    },
    {
      "from": 331.0,
      "to": 333.0,
      "content": "可见柳家媳妇应付司棋"
    },
    {
      "from": 333.0,
      "to": 335.0,
      "content": "已是常态了"
    },
    {
      "from": 335.0,
      "to": 337.0,
      "content": "以司棋的豹脾气"
    },
    {
      "from": 337.0,
      "to": 338.0,
      "content": "吃到馊豆腐"
    },
    {
      "from": 338.0,
      "to": 340.0,
      "content": "而没有找厨房的麻烦"
    },
    {
      "from": 340.0,
      "to": 342.0,
      "content": "已算是奇迹了"
    },
    {
      "from": 342.0,
      "to": 343.0,
      "content": "她可能认为"
    },
    {
      "from": 343.0,
      "to": 345.0,
      "content": "这是厨房一时的失误"
    },
    {
      "from": 345.0,
      "to": 348.0,
      "content": "没有怀疑这是柳家媳妇成心"
    },
    {
      "from": 349.0,
      "to": 350.0,
      "content": "这次炖鸡蛋"
    },
    {
      "from": 350.0,
      "to": 353.0,
      "content": "被莲花儿添油加醋说了一通"
    },
    {
      "from": 353.0,
      "to": 356.0,
      "content": "就演变成了一场风波"
    },
    {
      "from": 356.0,
      "to": 358.0,
      "content": "而从炖鸡蛋这次"
    },
    {
      "from": 358.0,
      "to": 360.0,
      "content": "柳家媳妇的态度来看"
    },
    {
      "from": 360.0,
      "to": 362.56,
      "content": "之前的馊豆腐显然是故意的"
    },
    {
      "from": 364.36,
      "to": 366.92,
      "content": "柳家媳妇的确有为难的地方"
    },
    {
      "from": 367.42,
      "to": 370.76,
      "content": "如果人人都像司棋这样来要东要西"
    },
    {
      "from": 371.0,
      "to": 374.08,
      "content": "厨房的正常工作必然会受到影响"
    },
    {
      "from": 374.6,
      "to": 376.64,
      "content": "所以除了晴雯芳官"
    },
    {
      "from": 376.9,
      "to": 379.2,
      "content": "这些具有利益关联的丫鬟"
    },
    {
      "from": 379.46,
      "to": 381.24,
      "content": "其他丫鬟的要求"
    },
    {
      "from": 381.5,
      "to": 384.32,
      "content": "柳家媳妇都在想办法拒绝"
    },
    {
      "from": 384.58,
      "to": 388.16,
      "content": "甚至不惜采取给馊豆腐这样的操作"
    },
    {
      "from": 388.92,
      "to": 390.72,
      "content": "但我们也要意识到"
    },
    {
      "from": 390.98,
      "to": 393.28,
      "content": "柳家媳妇绝不是个善茬"
    },
    {
      "from": 394.04,
      "to": 397.12,
      "content": "能坐在大观园厨房管家这个位置上"
    },
    {
      "from": 397.38,
      "to": 399.94,
      "content": "管辖手底下一群媳妇婆子"
    },
    {
      "from": 400.2,
      "to": 402.24,
      "content": "一定要有些手段才行"
    },
    {
      "from": 402.76,
      "to": 405.56,
      "content": "所以曹雪芹特地写了这么一段文字"
